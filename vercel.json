{
  "version": 2,
  "env": {
    "POSTGRES_URL": "postgresql://neondb_owner:npg_n6tRUYLQz1Kc@ep-holy-fog-amgnwiu5-pooler.c-5.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require"
  },
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
